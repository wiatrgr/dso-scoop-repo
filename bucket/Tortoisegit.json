{
    "version": "2.16.0.0",
    "homepage": "https://tortoisegit.org/",
    "license": "https://www.gnu.org/licenses/gpl-2.0",
    "architecture": {
        "64bit": {
            "url": "https://download.tortoisegit.org/tgit/2.16.0.0/TortoiseGit-2.16.0.0-64bit.msi",
            "hash": "md5:0a51e2003e780c3fdfad4924a80a0c2f"
        },
        "32bit": {
            "url": "https://download.tortoisegit.org/tgit/2.16.0.0/TortoiseGit-2.16.0.0-32bit.msi",
            "hash": "md5:a13b4c40f1eaca16dfacb69853e942a0"
        }
    },
    "extract_dir": [
        "Program Files\\TortoiseGit",
        "Program Files\\TortoiseGit"
    ],
    "env_add_path": "bin",
    "bin": [
        "bin\\TortoiseGitMerge.exe",
        "bin\\TortoiseGitIDiff.exe",
        "bin\\TortoiseGitBlame.exe",
        "bin\\TortoiseGitProc.exe //command:rtfm",
        "bin\\TortoiseGitProc.exe //command:settings"
    ],
    "shortcuts": [
        [
            "TortoiseGitMerge.exe",
            "TortoiseGitMerge"
        ],
        [
            "TortoiseGitIDiff.exe",
            "TortoiseGitIDiff"
        ],
        [
            "TortoiseGitBlame.exe",
            "TortoiseGitBlame"
        ],
        [
            "TortoiseGitProc.exe //command:rtfm",
            "TortoiseGit"
        ],
        [
            "TortoiseGitProc.exe //command:settings",
            "Settings"
        ]
    ],
    "post_install": [
        "[Environment]::SetEnvironmentVariable(\"GIT_INSTALL_ROOT\", \"C:\\ProgramData\\scoop\\apps\\git\\current\bin\", \"Machine\")"
    ],
    "checkver": {
        "url": "https://tortoisegit.org/download/",
        "re": "download.tortoisegit.org/tgit/([\\d\\.]+)/"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://download.tortoisegit.org/tgit/$version/TortoiseGit-$version-64bit.msi"
            },
            "32bit": {
                "url": "https://download.tortoisegit.org/tgit/$version/TortoiseGit-$version-32bit.msi"
            }
        }
    }
}
