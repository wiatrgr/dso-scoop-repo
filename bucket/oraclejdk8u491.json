{
    "version": "8u491",
    "description": "Oracle JDK 8 with strict previous-version cacerts migration",
    "homepage": "https://www.oracle.com/java/",
    "license": "https://www.oracle.com/downloads/licenses/no-fee-license.html",

    "architecture": {
        "64bit": {
            "url": "https://scoop-packages.itsmtaxud.priv/packages/oraclejdk/jdk-8u491-windows-x64.zip",
            "hash": "fd66c07e474209d249313bdc7bf3ff47982b4db6d05fe6c01a1544533bd9bd16"
        }
    },

    "extract_dir": "jdk1.8.0_491",

    "env_add_path": "bin",
    "env_set": {
        "JAVA_HOME": "$dir"
    },

    "post_install": [
        "$dst = Join-Path $dir 'jre\\lib\\security\\cacerts'",

        "# znajdź poprzednią wersję Oracle JDK 8 (NIE current)",
        "$apps = Get-ChildItem 'C:\\ProgramData\\scoop\\apps\\oraclejdk8*' -Directory |",
        "    Where-Object { $_.Name -match 'oraclejdk8u\\d+' } |",
        "    Sort-Object Name -Descending",

        "$src = $apps | ForEach-Object {",
        "    $p = Join-Path $_.FullName 'jre\\lib\\security\\cacerts'",
        "    if (Test-Path $p) { $p }",
        "} | Select-Object -First 1",

        "if ($src -and (Test-Path $src)) {",
        "    Copy-Item $src $dst -Force",
        "    Write-Host \"Oracle JDK8: cacerts migrated from previous install\"",
        "}"
    ]
}
