{
    "version": "8u491",
    "description": "Oracle JDK 8 with config-driven cacerts migration",
    "homepage": "https://www.oracle.com/java/",
    "license": "https://www.oracle.com/downloads/licenses/no-fee-license.html",

    "architecture": {
        "64bit": {
            "url": "https://scoop-packages.itsmtaxud.priv/packages/oraclejdk/jdk-8u491-windows-x64.zip",
            "hash": "fd66c07e474209d249313bdc7bf3ff47982b4db6d05fe6c01a1544533bd9bd16"
        }
    },

    "extract_dir": "jdk1.8.0_491",

    "env_add_path": "bin",
    "env_set": {
        "JAVA_HOME": "$dir"
    },

    "post_install": [
        "$config = 'C:\\ProgramData\\scoop\\java-cacerts-map.json'",
        "$key = 'oraclejdk8u491'",

        "if (!(Test-Path $config)) { Write-Host 'Missing config'; return }",

        "$map = Get-Content $config -Raw | ConvertFrom-Json",
        "$sourceApp = $map.$key",

        "if (!$sourceApp) { Write-Host 'No mapping for key'; return }",

        "$appRoot = Join-Path 'C:\\ProgramData\\scoop\\apps' $sourceApp",

        "$source = Get-ChildItem $appRoot -Recurse -Filter cacerts -ErrorAction SilentlyContinue | Select-Object -First 1",

        "if (!$source) { Write-Host 'cacerts not found in source'; return }",

        "$destination = Join-Path $dir 'jre\\lib\\security\\cacerts'",

        "Copy-Item $source.FullName $destination -Force",
        "Write-Host \"cacerts copied from $($source.FullName)\""
    ]
}
