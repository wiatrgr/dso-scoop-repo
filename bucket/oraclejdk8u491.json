{
    "version": "8u491",
    "description": "Oracle JDK 8 with config-driven cacerts migration",
    "homepage": "https://www.oracle.com/java/",
    "license": "https://www.oracle.com/downloads/licenses/no-fee-license.html",

    "architecture": {
        "64bit": {
            "url": "https://scoop-packages.itsmtaxud.priv/packages/oraclejdk/jdk-8u491-windows-x64.zip",
            "hash": "fd66c07e474209d249313bdc7bf3ff47982b4db6d05fe6c01a1544533bd9bd16"
        }
    },

    "extract_dir": "jdk1.8.0_491",

    "env_add_path": "bin",
    "env_set": {
        "JAVA_HOME": "$dir"
    },

    "post_install": [
        "$cfg = 'C:\\ProgramData\\scoop\\java-cacerts-map.json'",
        "$map = Get-Content $cfg -Raw | ConvertFrom-Json",

        "$key = 'oraclejdk8u491'",
        "$srcName = $map.$key",

        "$srcRoot = Get-ChildItem \"C:\\ProgramData\\scoop\\apps\\$srcName\" -Directory -ErrorAction SilentlyContinue | Select-Object -First 1",
        "$src = if ($srcRoot) { Join-Path $srcRoot.FullName 'jre\\lib\\security\\cacerts' }",

        "$dst = Join-Path $dir 'jre\\lib\\security\\cacerts'",

        "if ($src -and (Test-Path $src)) {",
        "    Copy-Item $src $dst -Force",
        "    Write-Host 'Oracle JDK8u491: cacerts copied via config map'",
        "}"
    ]
}
