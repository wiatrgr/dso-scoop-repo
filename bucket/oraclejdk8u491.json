{
    "version": "8u491",
    "description": "Oracle JDK 8 with simple cacerts handling",
    "homepage": "https://www.oracle.com/java/",
    "license": "https://www.oracle.com/downloads/licenses/no-fee-license.html",

    "architecture": {
        "64bit": {
            "url": "https://scoop-packages.itsmtaxud.priv/packages/oraclejdk/jdk-8u491-windows-x64.zip",
            "hash": "fd66c07e474209d249313bdc7bf3ff47982b4db6d05fe6c01a1544533bd9bd16"
        }
    },

    "extract_dir": "jdk1.8.0_491",

    "env_add_path": "bin",
    "env_set": {
        "JAVA_HOME": "$dir"
    },

    "post_install": [
        "$source = Join-Path $dir 'jre\\lib\\security\\cacerts'",

        "if (!(Test-Path $source)) {",
        "    $source = Join-Path $dir 'lib\\security\\cacerts'",
        "}",

        "if (!(Test-Path $source)) {",
        "    Write-Host 'cacerts not found'",
        "    return",
        "}",

        "$destination = Join-Path $dir 'jre\\lib\\security\\cacerts'",

        "Copy-Item $source $destination -Force",

        "Write-Host 'Oracle JDK8 cacerts synced'"
    ]
}
