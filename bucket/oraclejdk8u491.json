{
    "version": "8u491",
    "description": "Oracle JDK 8 with strict previous-version cacerts migration",
    "homepage": "https://www.oracle.com/java/",
    "license": "https://www.oracle.com/downloads/licenses/no-fee-license.html",

    "architecture": {
        "64bit": {
            "url": "https://scoop-packages.itsmtaxud.priv/packages/oraclejdk/jdk-8u491-windows-x64.zip",
            "hash": "fd66c07e474209d249313bdc7bf3ff47982b4db6d05fe6c01a1544533bd9bd16"
        }
    },

    "extract_dir": "jdk1.8.0_491",

    "env_add_path": "bin",
    "env_set": {
        "JAVA_HOME": "$dir"
    },

    "checkver": {
        "url": "https://scoop-packages.itsmtaxud.priv/packages/oraclejdk",
        "useragent": "curl/7",
        "regex": "JDK Development Kit ([\\d.]+) downloads"
    },

    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://scoop-packages.itsmtaxud.priv/packages/oraclejdk/jdk-$version_windows-x64_bin.zip"
            }
        },
        "hash": {
            "url": "$url.sha256"
        },
        "extract_dir": "jdk-$version"
    },

    "post_install": [
        "$src = 'C:\\ProgramData\\scoop\\apps\\oraclejdk8u481\\current\\jre\\lib\\security\\cacerts'",
        "$dst = Join-Path $dir 'jre\\lib\\security\\cacerts'",

        "if (Test-Path $src) {",
        "    Copy-Item $src $dst -Force",
        "    Write-Host 'Oracle JDK8u491: cacerts copied from 8u481'",
        "}"
    ]
}
