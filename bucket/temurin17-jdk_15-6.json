{
    "description": "Eclipse Temurin 17",
    "homepage": "https://adoptium.net",
    "version": "17.0.15-6",
    "license": "GPL-2.0-only WITH Classpath-exception-2.0",

    "architecture": {
        "64bit": {
            "url": "https://github.com/adoptium/temurin17-binaries/releases/download/jdk-17.0.15%2B6/OpenJDK17U-jdk_x64_windows_hotspot_17.0.15_6.zip",
            "hash": "118CF8D586EE3200E2D2E6E49717DB4FB1A22005700FBF85F06166046EC74863"
        }
    },

    "extract_dir": "jdk-17.0.15+6",

    "env_add_path": "bin",
    "env_set": {
        "JAVA_HOME": "$dir"
    },

    "post_install": [
        "$source = Join-Path $dir 'lib\\security\\cacerts'",

        "if (!(Test-Path $source)) {",
        "    Write-Host 'cacerts not found'",
        "    return",
        "}",

        "Write-Host 'Temurin uses lib\\security\\cacerts - no copy needed'"
    ]
}
