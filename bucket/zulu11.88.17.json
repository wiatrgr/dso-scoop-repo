    },

    "architecture": {
        "64bit": {
            "url": "https://cdn.azul.com/zulu/bin/zulu11.88.17-ca-jdk11.0.31-win_x64.zip",
            "hash": "76c6592dc7ae74db7b8bf4612a13a000209277c1da670dc1d0bcc1d3460e4425",
            "extract_dir": "zulu11.88.17-ca-jdk11.0.31-win_x64"
        }
    },

    "env_add_path": "bin",
    "env_set": {
        "JAVA_HOME": "$dir"
    },

    "post_install": [
        "$source = Join-Path $dir 'lib\\security\\cacerts'",

        "if (!(Test-Path $source)) {",
        "    Write-Host 'cacerts not found'",
        "    return",
        "}",

        "Write-Host 'Zulu uses lib\\security\\cacerts - no copy needed'"
    ]
}
