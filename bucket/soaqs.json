{
    "version": "12.2.1.4.0",
    "description": "Oracle SOA Suite Quickstart 12c",
    "homepage": "https://www.oracle.com/middleware/soa/",
    "license": "Oracle",
    "architecture": {
        "64bit": {
            "url": "https://scoop-packages.itsmtaxud.priv/packages/soaqs/V983385-01.zip",
            "hash": "13e4a89b8f2b0a238ca2071387ea85db9ed3bbaedf084b10258e2b56328d9288"
        }
    },
    "extract_dir": "",
    "installer": {
        "script": [
            "# 1. Find the QuickStart JAR",
            "$jar = Get-ChildItem $dir -Recurse -Filter *.jar | Where-Object { $_.Name -match 'soa.*quickstart' } | Select-Object -First 1",
            "if (-not $jar) { Write-Error 'SOA QuickStart JAR not found!'; exit 1 }",

            "# 2. Run silent install",
            "Write-Host 'Starting Oracle SOA QuickStart installation...'",
            "& java -jar $jar.FullName -silent -responseFile \"$dir\\soa_quickstart.rsp\"",

            "# 3. Create Start Menu shortcuts",
            "$startMenu = [Environment]::GetFolderPath('StartMenu') + '\\Programs\\Scoop Apps'",
            "if (-not (Test-Path $startMenu)) { New-Item -ItemType Directory -Path $startMenu -Force | Out-Null }",

            "$shell = New-Object -ComObject WScript.Shell",

            "# Define icon path (must be .ico for proper display)",
            "$iconPath = \"$dir\\oracle_icon.ico\"",

            "# Shortcut 1: JDeveloper",
            "$shortcut1 = $shell.CreateShortcut($startMenu + '\\JDeveloper.lnk')",
            "$shortcut1.TargetPath = 'C:\\Oracle\\Middleware\\jdeveloper\\jdeveloper.exe'",
            "$shortcut1.WorkingDirectory = 'C:\\Oracle\\Middleware\\jdeveloper\\'",
            "$shortcut1.Save()",

            "# Shortcut 2: Admin Server",
            "$shortcut2 = $shell.CreateShortcut($startMenu + '\\Oracle SOA QuickStart Admin Server.lnk')",
            "$shortcut2.TargetPath = 'C:\\Oracle\\Middleware\\user_projects\\domains\\base_domain\\startWebLogic.cmd'",
            "$shortcut2.WorkingDirectory = 'C:\\Oracle\\Middleware\\user_projects\\domains\\base_domain'",
            "$shortcut2.IconLocation = $iconPath",
            "$shortcut2.Save()",

            "# 4. Inform user",
            "Write-Host 'Installation complete.'",
            "Write-Host 'Use Start Menu -> Scoop Apps to run Config or Admin Server.'"
        ]
    },
    "checkver": {
        "regex": "V([\\d-]+)\\.zip"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://scoop-packages.itsmtaxud.priv/packages/soaqs/V$version.zip"
            }
        }
    }
}
