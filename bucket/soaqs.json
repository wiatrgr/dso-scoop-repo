{
    "version": "12.2.1.4.0",
    "description": "Oracle SOA Suite Quickstart 12c",
    "homepage": "https://www.oracle.com/middleware/soa/",
    "license": "Oracle",
    "architecture": {
        "64bit": {
            "url": "https://scoop-packages.itsmtaxud.priv/packages/soaqs/V983385-01.zip",
            "hash": "7a0c3e5307f9a0abd69bed9954c75e78c4d50bee68d7d49c2f09a2c05995e06c"
        }
    },
    "extract_dir": "",
    "installer": {
        "script": [
            "# 1. Find the QuickStart JAR",
            "$jar = Get-ChildItem $dir -Recurse -Filter *.jar | Where-Object { $_.Name -match 'soa.*quickstart' } | Select-Object -First 1",
            "if (-not $jar) { Write-Error 'SOA QuickStart JAR not found!'; exit 1 }",

            "# 2. Run silent install",
            "Write-Host 'Starting Oracle SOA QuickStart installation...'",
            "& java -jar $jar.FullName -silent -responseFile \"$dir\\soa_quickstart.rsp\"",

            "# 3. Inform user",
            "Write-Host '✅ Installation complete.'",
            "Write-Host 'Use Start Menu -> Oracle SOA QuickStart to run config.cmd or start Admin Server.'"
        ]
    },
    "bin": "wlserver\\common\\bin\\config.cmd",
    "shortcuts": [
        ["wlserver\\common\\bin\\config.cmd", "Oracle SOA QuickStart Config"],
        ["user_projects\\domains\\soa_quickstart\\startWebLogic.cmd", "Oracle SOA QuickStart Admin Server"]
    ],
    "checkver": {
        "regex": "V([\\d-]+)\\.zip"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://scoop-packages.itsmtaxud.priv/packages/soaqs/V$version.zip"
            }
        }
    }
}
