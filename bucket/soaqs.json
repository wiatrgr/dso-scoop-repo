{
    "version": "12.2.1.4.0",
    "description": "Oracle SOA Suite Quickstart 12c",
    "homepage": "https://www.oracle.com/middleware/soa/",
    "license": "Oracle",
    "architecture": {
        "64bit": {
            "url": "https://scoop-packages.itsmtaxud.priv/packages/soaqs/V983385-01.zip",
            "hash": "79b3bce2421a75b1e90c0d636ad80a3bae8ef4f518e2870256ecedbe24621a76"
        }
    },
    "extract_dir": "",
    "installer": {
        "script": [
            "# 1. Find installer JAR",
            "$jar = Get-ChildItem $dir -Recurse -Filter *.jar | Where-Object { $_.Name -match 'soa_quickstart' } | Select-Object -First 1",
            "if (-not $jar) {",
            "    Write-Error 'JAR installer not found!'",
            "    exit 1",
            "}",
            "",
            "# 2. Silent install using RSP (SOA QuickStart, no domain)",
            "Write-Host 'Starting Oracle SOA QuickStart installation...'",
            "& java -jar $jar.FullName -silent -responseFile \"$dir\\soa_quickstart.rsp\"",
            "",
            "# 3. Define Middleware home",
            "$MW_HOME = 'C:\\Oracle\\Middleware'",
            "$WLST = \"$MW_HOME\\oracle_common\\common\\bin\\wlst.cmd\"",
            "",
            "# 4. Wait for WLST to exist",
            "$timeout = 120",
            "while (!(Test-Path $WLST) -and $timeout -gt 0) { Start-Sleep -Seconds 2; $timeout-- }",
            "if (!(Test-Path $WLST)) { Write-Error 'wlst.cmd not found! Installation likely failed.'; exit 1 }",
            "",
            "# 5. Create SOA domain using WLST + your create_soa_domain.py",
            "$domain_script = \"$dir\\create_soa_domain.py\"",
            "Write-Host 'Creating SOA domain using WLST...'",
            "& $WLST $domain_script",
            "",
            "# 6. Report the domain path",
            "$DOMAIN_HOME = 'C:\\Oracle\\Middleware\\user_projects\\domains\\soa_quickstart'",
            "if (Test-Path $DOMAIN_HOME) { Write-Host 'SOA Domain created successfully at:' $DOMAIN_HOME }",
            "else { Write-Warning 'Domain not found. Check WLST logs.' }"
        ]
    },
    "checkver": {
        "regex": "V([\\d-]+)\\.zip"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://scoop-packages.itsmtaxud.priv/packages/soaqs/V$version.zip"
            }
        }
    }
}
